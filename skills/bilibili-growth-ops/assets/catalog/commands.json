    },
    {
      "key": "records.cooldown-policy-set",
      "group": "records",
      "command": "cooldown-policy-set",
      "resultId": "records.cooldown_policy_set",
      "title": "更新中心化节流规则",
      "summary": "精确更新某类外发动作的中心化节流规则，供后续所有节流检查统一读取。",
      "requiredOptions": ["operationType"],
      "optionalOptions": ["cooldownSeconds", "windowMinutes", "maxInWindow", "recentLimit", "replace", "runtimeRoot"],
      "writesOperationRecord": false,
      "usage": "node scripts/ops.js records cooldown-policy-set --operationType direct_message --cooldownSeconds 180 --windowMinutes 60 --maxInWindow 20",
      "notes": ["适合 Agent 把用户的自然语言要求翻译成精确配置更新。", "默认是局部更新，只改传入的字段。", "如果传入 `--replace true`，则会用本次字段整体替换该操作类型的已持久化规则。", "更新后，`records.cooldown-check`、`comment.send`、`dm.send` 会统一读取这份规则。"]
    },
